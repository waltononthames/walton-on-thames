---
interface Props {
  name: string;
  slug: string;
  category: string;
  neighbourhood: string;
  description: string;
  images?: string[];
}

const { name, slug, category, neighbourhood, description, images = [] } = Astro.props;

const categoryLabel = category.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
const thumbUrl = images[0] ?? null;
---

<a href={`/things-to-do/${slug}/`} class="card place-card">
  {thumbUrl
    ? <img class="card-image" src={thumbUrl} alt={name} loading="lazy" />
    : <div class="card-image-placeholder" aria-hidden="true">🌿</div>
  }
  <div class="card-body">
    <span class="card-category">{categoryLabel}</span>
    <h3 class="card-title">{name}</h3>
    <p class="card-description">{description}</p>
    <span class="badge">{neighbourhood.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase())}</span>
  </div>
</a>
