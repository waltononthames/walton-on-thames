---
interface Props {
  title: string;
  slug: string;
  start: string;
  venue: string;
  category: string;
  price: string;
  image?: string;
  description?: string;
}

const { title, slug, start, venue, category, price, image, description } = Astro.props;

const date = new Date(start);
const dateStr = date.toLocaleDateString('en-GB', { weekday: 'short', day: 'numeric', month: 'long' });
const timeStr = date.toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit' });
const categoryLabel = category.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
---

<a href={`/whats-on/${slug}/`} class="card event-card">
  {image
    ? <img class="card-image" src={image} alt={title} loading="lazy" />
    : <div class="card-image-placeholder" aria-hidden="true">📅</div>
  }
  <div class="card-body">
    <span class="card-category">{categoryLabel}</span>
    <h3 class="card-title">{title}</h3>
    {description && <p class="card-description">{description}</p>}
    <div class="event-meta">
      <span class="event-date">{dateStr} · {timeStr}</span>
      <span class="event-venue">{venue}</span>
      <span class="badge badge-accent">{price}</span>
    </div>
  </div>
</a>

<style>
  .event-meta {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    margin-top: auto;
  }

  .event-date {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-navy);
  }

  .event-venue {
    font-size: 0.8rem;
    color: var(--color-slate);
  }
</style>
