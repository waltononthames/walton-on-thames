---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BusinessCard from '../../components/BusinessCard.astro';
import { getCollection } from 'astro:content';

const businesses = await getCollection('businesses');
const eatDrink = businesses.filter(b =>
  ['eat-and-drink', 'pubs-and-bars', 'cafes', 'restaurants', 'takeaways'].includes(b.data.category)
);

const categories = [
  { slug: 'restaurants', label: 'Restaurants' },
  { slug: 'pubs-and-bars', label: 'Pubs & Bars' },
  { slug: 'cafes', label: 'Cafes' },
  { slug: 'takeaways', label: 'Takeaways' },
];
---

<BaseLayout
  title="Eat & Drink in Walton-on-Thames — Restaurants, Pubs & Cafes"
  description="The best places to eat and drink in Walton-on-Thames, Hersham and Whiteley Village — from riverside pubs to Italian restaurants, cafes and takeaways."
>
  <slot name="structured-data">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://walton-on-thames.org/" },
        { "@type": "ListItem", "position": 2, "name": "Eat & Drink", "item": "https://walton-on-thames.org/eat-and-drink/" }
      ]
    })} />
  </slot>

  <div class="page-hero">
    <div class="container">
      <nav aria-label="Breadcrumb">
        <ol class="breadcrumbs">
          <li><a href="/">Home</a></li>
          <li aria-current="page">Eat & Drink</li>
        </ol>
      </nav>
      <h1>Eat & Drink</h1>
      <p>From riverside pubs with Thames views to independent restaurants and neighbourhood cafes — Walton has a genuinely good food and drink scene.</p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="cat-tabs">
        {categories.map(cat => (
          <a href={`/eat-and-drink/${cat.slug}/`} class="cat-tab">{cat.label}</a>
        ))}
      </div>

      {eatDrink.length > 0 ? (
        <div class="card-grid card-grid-3">
          {eatDrink.map(biz => (
            <BusinessCard
              name={biz.data.name}
              slug={biz.data.slug}
              category={biz.data.category}
              neighbourhood={biz.data.neighbourhood}
              description={biz.data.description}
              images={biz.data.images}
              featured={biz.data.featured}
            />
          ))}
        </div>
      ) : (
        <p class="empty-state">Eat & drink listings are being added — check back soon, or <a href="/directory/">browse the full directory</a>.</p>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .cat-tabs {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }

  .cat-tab {
    padding: 0.5rem 1.25rem;
    border: 1.5px solid rgba(11,36,46,0.15);
    border-radius: 999px;
    font-size: 0.875rem;
    font-weight: 500;
    text-decoration: none;
    color: var(--color-navy);
    transition: background 0.15s, border-color 0.15s;
  }

  .cat-tab:hover {
    background: var(--color-navy);
    border-color: var(--color-navy);
    color: var(--color-white);
  }

  .empty-state {
    color: var(--color-slate);
    font-size: 1.05rem;
    padding: 2rem 0;
  }
</style>
