---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Privacy Policy — Walton-on-Thames.org"
  description="Privacy policy for Walton-on-Thames.org — how we use cookies, analytics, and personal data."
  noIndex={true}
>
  <div class="page-hero">
    <div class="container">
      <nav aria-label="Breadcrumb">
        <ol class="breadcrumbs">
          <li><a href="/">Home</a></li>
          <li aria-current="page">Privacy Policy</li>
        </ol>
      </nav>
      <h1>Privacy Policy</h1>
      <p>Last updated: June 2026</p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="prose">
        <h2>Who we are</h2>
        <p>Walton-on-Thames.org is an independent community website covering Walton-on-Thames, Hersham and Whiteley Village. This policy explains how we handle personal data.</p>

        <h2>What data we collect</h2>
        <p><strong>Analytics:</strong> This site uses Cloudflare Web Analytics, which is privacy-friendly and does not use cookies or collect personal data. It measures aggregate page visit counts and browser types. No individual user is identified or tracked.</p>
        <p><strong>Contact form:</strong> If you submit our contact form, we receive your name, email address, and message. This data is used solely to respond to your enquiry and is not shared with third parties.</p>
        <p><strong>No cookies:</strong> This site does not use first-party cookies or tracking cookies. Cloudflare, our hosting and CDN provider, may set technical cookies necessary for site operation — see <a href="https://www.cloudflare.com/privacypolicy/" target="_blank" rel="noopener noreferrer">Cloudflare's privacy policy</a>.</p>

        <h2>Third-party services</h2>
        <ul>
          <li><strong>Cloudflare Pages / Cloudflare CDN:</strong> our hosting and content delivery network. Subject to <a href="https://www.cloudflare.com/privacypolicy/" target="_blank" rel="noopener noreferrer">Cloudflare's privacy policy</a>.</li>
          <li><strong>OpenStreetMap:</strong> map embeds on listing pages are served by OpenStreetMap. Subject to <a href="https://wiki.osmfoundation.org/wiki/Privacy_Policy" target="_blank" rel="noopener noreferrer">OpenStreetMap Foundation's privacy policy</a>.</li>
        </ul>

        <h2>Your rights</h2>
        <p>If you have submitted data via our contact form and wish to have it deleted, please <a href="/contact/">contact us</a>. We will respond within 30 days.</p>

        <h2>Changes to this policy</h2>
        <p>We may update this policy from time to time. The date at the top of this page shows when it was last revised.</p>

        <h2>Contact</h2>
        <p>For privacy-related queries, use our <a href="/contact/">contact form</a>.</p>
      </div>
    </div>
  </section>
</BaseLayout>
