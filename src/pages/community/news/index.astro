---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import NewsCard from '../../../components/NewsCard.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('news');
const sorted = posts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<BaseLayout
  title="Local News — Walton-on-Thames Community News & Stories"
  description="Local news, history features and community stories from Walton-on-Thames, Hersham and Whiteley Village."
>
  <slot name="structured-data">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://walton-on-thames.org/" },
        { "@type": "ListItem", "position": 2, "name": "News", "item": "https://walton-on-thames.org/community/news/" }
      ]
    })} />
  </slot>

  <div class="page-hero">
    <div class="container">
      <nav aria-label="Breadcrumb">
        <ol class="breadcrumbs">
          <li><a href="/">Home</a></li>
          <li aria-current="page">News</li>
        </ol>
      </nav>
      <h1>Local News & Stories</h1>
      <p>Community news, local history, and stories from across Walton-on-Thames, Hersham and Whiteley Village.</p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="card-grid card-grid-3">
        {sorted.map(post => (
          <NewsCard
            title={post.data.title}
            slug={post.data.slug}
            date={post.data.date}
            category={post.data.category}
            description={post.data.description}
            image={post.data.image}
          />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
