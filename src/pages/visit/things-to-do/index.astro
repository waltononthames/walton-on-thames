---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PlaceCard from '../../../components/PlaceCard.astro';
import { getCollection } from 'astro:content';

const places = await getCollection('places');
const sorted = places.sort((a, b) => a.data.name.localeCompare(b.data.name));
---

<BaseLayout
  title="Things to Do in Walton-on-Thames — Attractions, Parks & Landmarks"
  description="Discover the best things to do in Walton-on-Thames, Hersham and Whiteley Village — riverside walks, heritage sites, parks and local attractions."
>
  <slot name="structured-data">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://walton-on-thames.org/" },
        { "@type": "ListItem", "position": 2, "name": "Visit", "item": "https://walton-on-thames.org/visit/" },
        { "@type": "ListItem", "position": 3, "name": "Things to Do", "item": "https://walton-on-thames.org/visit/things-to-do/" }
      ]
    })} />
  </slot>

  <div class="page-hero">
    <div class="container">
      <nav aria-label="Breadcrumb">
        <ol class="breadcrumbs">
          <li><a href="/">Home</a></li>
          <li><a href="/visit/">Visit</a></li>
          <li aria-current="page">Things to Do</li>
        </ol>
      </nav>
      <h1>Things to Do</h1>
      <p>Riverside walks, heritage villages, parks and green spaces — there's more to explore than you might think.</p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="card-grid card-grid-3">
        {sorted.map(place => (
          <PlaceCard
            name={place.data.name}
            slug={place.data.slug}
            category={place.data.category}
            neighbourhood={place.data.neighbourhood}
            description={place.data.description}
            images={place.data.images}
          />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
