---
import BaseLayout from '../../layouts/BaseLayout.astro';
import EventCard from '../../components/EventCard.astro';
import { getCollection } from 'astro:content';

const events = await getCollection('events');

// Filter to events whose end date (or start date if no end) is today or in the future.
// "Today" is midnight at build time — Cloudflare Pages rebuilds nightly so past events
// drop off the site the morning after they finish.
const today = new Date();
today.setHours(0, 0, 0, 0);

function eventEndDay(e: (typeof events)[number]): Date {
  const d = new Date(e.data.end ?? e.data.start);
  d.setHours(0, 0, 0, 0);
  return d;
}

const upcoming = events
  .filter(e => eventEndDay(e) >= today)
  .sort((a, b) => new Date(a.data.start).getTime() - new Date(b.data.start).getTime());
---

<BaseLayout
  title="What's On in Walton-on-Thames — Events, Festivals & Things to Do"
  description="Events and things to do in Walton-on-Thames, Hersham and Whiteley Village — festivals, markets, community events, sport and more."
>
  <slot name="structured-data">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://walton-on-thames.org/" },
        { "@type": "ListItem", "position": 2, "name": "What's On", "item": "https://walton-on-thames.org/whats-on/" }
      ]
    })} />
  </slot>

  <div class="page-hero">
    <div class="container">
      <nav aria-label="Breadcrumb">
        <ol class="breadcrumbs">
          <li><a href="/">Home</a></li>
          <li aria-current="page">What's On</li>
        </ol>
      </nav>
      <h1>What's On</h1>
      <p>Events, festivals, markets and community activities across Walton-on-Thames, Hersham and Whiteley Village.</p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      {upcoming.length > 0 ? (
        <>
          <div class="section-header">
            <h2>Upcoming Events</h2>
          </div>
          <div class="card-grid card-grid-3">
            {upcoming.map(event => (
              <EventCard
                title={event.data.title}
                slug={event.data.slug}
                start={event.data.start}
                venue={event.data.venue}
                category={event.data.category}
                price={event.data.price}
                image={event.data.image}
                description={event.data.description}
              />
            ))}
          </div>
        </>
      ) : (
        <p class="empty-state">No upcoming events right now — check back soon or <a href="/community/news/">read the local news</a>.</p>
      )}

      <div class="submit-event">
        <p>Know of an event that should be listed here?</p>
        <a href="/contact/?subject=Event+submission" class="btn btn-primary">Submit an event</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .empty-state {
    color: var(--color-slate);
    font-size: 1.05rem;
    padding: 2rem 0;
  }

  .submit-event {
    margin-top: 3rem;
    padding: 2rem;
    background: var(--color-white);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .submit-event p { color: var(--color-slate); }
</style>
