---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const businesses = await getCollection('businesses');
const accommodation = businesses
  .filter(b => b.data.category === 'accommodation')
  .sort((a, b) => a.data.name.localeCompare(b.data.name));

const local = accommodation.filter(b => ['walton-on-thames', 'hersham'].includes(b.data.neighbourhood));
const weybridge = accommodation.filter(b => b.data.neighbourhood === 'weybridge');
const shepperton = accommodation.filter(b => b.data.neighbourhood === 'shepperton');
const esher = accommodation.filter(b => b.data.neighbourhood === 'esher');

const typeLabels: Record<string, string> = {
  'hotel': 'Hotel',
  'bed-and-breakfast': 'B&B',
  'pub-with-rooms': 'Pub with rooms',
  'guest-house': 'Guest house',
  'inn': 'Inn',
};

function getTypeLabel(subcategories: string[]): string {
  for (const sub of subcategories) {
    if (typeLabels[sub]) return typeLabels[sub];
  }
  return 'Accommodation';
}

const nearbyGroups = [
  { label: 'Weybridge', items: weybridge },
  { label: 'Shepperton', items: shepperton },
  { label: 'Esher', items: esher },
].filter(g => g.items.length > 0);
---

<BaseLayout
  title="Where to Stay Near Walton-on-Thames — Hotels & B&Bs"
  description="Hotels, B&Bs and inns in Walton-on-Thames and Hersham, plus well-regarded options within 3 miles in Weybridge, Shepperton and Esher."
>
  <slot name="structured-data">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://walton-on-thames.org/" },
        { "@type": "ListItem", "position": 2, "name": "Places to Stay", "item": "https://walton-on-thames.org/places-to-stay/" }
      ]
    })} />
  </slot>

  <div class="page-hero">
    <div class="container">
      <nav aria-label="Breadcrumb">
        <ol class="breadcrumbs">
          <li><a href="/">Home</a></li>
          <li aria-current="page">Places to Stay</li>
        </ol>
      </nav>
      <h1>Where to Stay Near Walton-on-Thames</h1>
      <p>Hotels, B&Bs and inns in Walton-on-Thames and Hersham, plus a selection of well-regarded options within 3 miles in Weybridge, Shepperton and Esher.</p>
    </div>
  </div>

  <!-- Local accommodation -->
  <section class="section" aria-labelledby="local-heading">
    <div class="container">
      <div class="section-header">
        <h2 id="local-heading">In Walton-on-Thames & Hersham</h2>
        <p>Accommodation within Walton-on-Thames and Hersham</p>
      </div>
      <div class="stay-list">
        {local.map(biz => (
          <div class="stay-card">
            <div class="stay-card-main">
              <div class="stay-meta">
                <span class="stay-type">{getTypeLabel(biz.data.subcategories)}</span>
                {biz.data.featured && <span class="stay-featured">Recommended</span>}
              </div>
              <h3 class="stay-name">
                <a href={`/directory/${biz.data.slug}/`}>{biz.data.name}</a>
              </h3>
              <p class="stay-desc">{biz.data.description}</p>
              <address class="stay-address">{biz.data.address}</address>
            </div>
            <div class="stay-card-links">
              <a href={`/directory/${biz.data.slug}/`} class="btn btn-outline stay-btn">View listing</a>
              {biz.data.website && (
                <a href={biz.data.website} class="stay-ext-link" target="_blank" rel="noopener noreferrer">
                  Visit website ↗
                </a>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Nearby accommodation -->
  <section class="section section-tinted" aria-labelledby="nearby-heading">
    <div class="container">
      <div class="section-header">
        <h2 id="nearby-heading">Nearby — Within 3 Miles</h2>
        <p>Well-regarded hotels and B&Bs in Weybridge, Shepperton and Esher — all a short drive or taxi from Walton-on-Thames</p>
      </div>

      {nearbyGroups.map(group => (
        <div class="area-group">
          <h3 class="area-heading">{group.label}</h3>
          <div class="stay-list">
            {group.items.map(biz => (
              <div class="stay-card">
                <div class="stay-card-main">
                  <div class="stay-meta">
                    <span class="stay-type">{getTypeLabel(biz.data.subcategories)}</span>
                    {biz.data.featured && <span class="stay-featured">Recommended</span>}
                  </div>
                  <h3 class="stay-name">
                    <a href={`/directory/${biz.data.slug}/`}>{biz.data.name}</a>
                  </h3>
                  <p class="stay-desc">{biz.data.description}</p>
                  <address class="stay-address">{biz.data.address}</address>
                </div>
                <div class="stay-card-links">
                  <a href={`/directory/${biz.data.slug}/`} class="btn btn-outline stay-btn">View listing</a>
                  {biz.data.website && (
                    <a href={biz.data.website} class="stay-ext-link" target="_blank" rel="noopener noreferrer">
                      Visit website ↗
                    </a>
                  )}
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .stay-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .stay-card {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 2rem;
    background: var(--color-white);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    box-shadow: var(--shadow-card);
    transition: box-shadow 0.2s;
  }

  .stay-card:hover { box-shadow: var(--shadow-card-hover); }

  .stay-card-main { flex: 1; }

  .stay-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }

  .stay-type {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    background: rgba(184, 134, 46, 0.1);
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
  }

  .stay-featured {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-navy);
    background: rgba(11, 36, 46, 0.08);
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
  }

  .stay-name {
    font-size: 1.1rem;
    margin-bottom: 0.4rem;
  }

  .stay-name a {
    color: var(--color-navy);
    text-decoration: none;
    transition: color 0.15s;
  }

  .stay-name a:hover { color: var(--color-accent); }

  .stay-desc {
    font-size: 0.9rem;
    color: var(--color-slate);
    line-height: 1.55;
    margin-bottom: 0.4rem;
  }

  .stay-address {
    font-style: normal;
    font-size: 0.8rem;
    color: var(--color-slate-soft);
  }

  .stay-card-links {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .stay-btn {
    white-space: nowrap;
    font-size: 0.8rem;
    padding: 0.4rem 0.875rem;
  }

  .stay-ext-link {
    font-size: 0.8rem;
    color: var(--color-slate);
    text-decoration: none;
    transition: color 0.15s;
    white-space: nowrap;
  }

  .stay-ext-link:hover { color: var(--color-accent); }

  .area-group { margin-bottom: 2.5rem; }

  .area-heading {
    font-size: 1.15rem;
    color: var(--color-navy);
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid rgba(11, 36, 46, 0.08);
  }

  @media (max-width: 640px) {
    .stay-card {
      flex-direction: column;
      gap: 1rem;
    }
    .stay-card-links {
      align-items: flex-start;
      flex-direction: row;
      flex-wrap: wrap;
    }
  }
</style>
